generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  phone        String?
  company      String?
  role         String   @default("customer")
  orders       Order[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Service {
  id               String          @id
  slug             String          @unique
  name             String
  shortDescription String
  fullDescription  String
  icon             String
  basePrice        Int
  isMonthly        Boolean         @default(false)
  timeline         String
  features         String[]
  options          ServiceOption[]
  upsells          ServiceUpsell[]
  orderItems       OrderItem[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model ServiceOption {
  id          String  @id @default(cuid())
  optionKey   String
  name        String
  description String
  price       Int
  isMonthly   Boolean @default(false)
  serviceId   String
  service     Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, optionKey])
}

model ServiceUpsell {
  id               String  @id @default(cuid())
  upsellKey        String
  name             String
  description      String
  kind             String?
  unit             String?
  pricePerUnit     Int?
  isMonthly        Boolean @default(false)
  min              Int?
  max              Int?
  defaultValue     Int?
  helperText       String?
  includedUnits    Int?
  tierStep         Int?
  tierPrice        Int?
  allowEntries     Boolean @default(false)
  entryLabel       String?
  entryPlaceholder String?
  choices          Json?
  serviceId        String
  service          Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, upsellKey])
}

model Order {
  id                     String               @id @default(cuid())
  userId                 String?
  user                   User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  customerName           String
  customerEmail          String
  customerPhone          String
  customerCompany        String?
  customerNotes          String?
  totalOneTime           Int
  totalMonthly           Int
  status                 String               @default("pending")
  consultationId         String?              @unique
  consultation           ConsultationBooking? @relation("OrderConsultation", fields: [consultationId], references: [id], onDelete: SetNull)
  items                  OrderItem[]
  pendingUserEmail       String?
  pendingUserPasswordHash String?
  pendingUserName        String?
  pendingUserPhone       String?
  pendingUserCompany     String?
  postCheckoutToken      String?              @unique
  invoiceWanted          Boolean              @default(false)
  invoiceData            Json?
  brandAssets            Json?
  subscriptionRenewsAt  DateTime?
  stripeCheckoutMode     String?
  stripeCheckoutSessionId String?             @unique
  stripePaymentIntentId  String?
  stripeSubscriptionId   String?
  stripeCustomerId       String?
  stripePaymentStatus    String?
  stripeCurrency         String?
  stripeAmountSubtotal   Int?
  stripeAmountTotal      Int?
  stripeAmountTax        Int?
  stripeMetadata         Json?
  stripeCheckoutCompletedAt DateTime?
  stripePaidAt           DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
}

model OrderItem {
  id                 String  @id @default(cuid())
  serviceId          String
  serviceName        String
  selectedOptionId   String
  selectedOptionName String
  basePrice          Int
  totalPrice         Int
  totalOneTime       Int
  totalMonthly       Int
  isMonthly          Boolean @default(false)
  upsells            Json
  orderId            String
  order              Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  service            Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)
}

model ConsultationBooking {
  id            String    @id
  name          String
  email         String
  phone         String
  company       String?
  notes         String?
  date          String
  time          String
  source        String
  status        String
  orderId       String?
  timezone      String    @default("Europe/Sofia")
  startsAt      DateTime?
  endsAt        DateTime?
  meetUrl       String?
  googleEventId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  linkedOrder   Order?    @relation("OrderConsultation")
}

model StripeCatalogMapping {
  id                String   @id @default(cuid())
  lookupKey         String   @unique
  serviceId         String
  serviceName       String
  selectedOptionId  String
  selectedOptionName String
  billingType       String
  unitAmount        Int
  currency          String   @default("eur")
  stripeProductId   String
  stripePriceId     String
  stripePaymentLinkId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model StripeCustomerMapping {
  id               String   @id @default(cuid())
  customerEmail    String   @unique
  customerName     String?
  stripeCustomerId String   @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model StripeWebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  eventType     String
  orderId       String?
  processedAt   DateTime @default(now())
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  eventType String   @map("event_type")
  page      String
  metadata  Json?
  sessionId String?  @map("session_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("analytics_events")
  @@index([eventType, page], map: "analytics_events_event_type_page_idx")
  @@index([createdAt], map: "analytics_events_created_at_idx")
  @@index([sessionId], map: "analytics_events_session_id_idx")
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("coming-soon")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("newsletter_subscribers")
}
