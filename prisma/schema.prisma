generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  passwordHash   String
  name           String?
  phone          String?
  company        String?
  role           String          @default("customer")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  orders         Order[]
  tenantProjects TenantProject[]
  supportChats   SupportChat[]
}

model SupportChat {
  id              String           @id @default(cuid())
  userId          String           @map("user_id")
  status          String           @default("open")
  adminJoinedAt   DateTime?        @map("admin_joined_at")
  adminNotifiedAt DateTime?        @map("admin_notified_at")
  closedAt        DateTime?        @map("closed_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages        SupportMessage[]

  @@index([userId, status])
  @@map("support_chats")
}

model SupportMessage {
  id           String      @id @default(cuid())
  chatId       String      @map("chat_id")
  senderType   String      @map("sender_type")
  senderUserId String?     @map("sender_user_id")
  body         String
  createdAt    DateTime    @default(now()) @map("created_at")
  chat         SupportChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
  @@map("support_messages")
}

model TenantProject {
  id               String    @id @default(cuid())
  userId           String
  orderId          String?
  productCategory  String    @default("clothing")
  templateId       String?
  previewSlug      String?   @unique
  setupStatus      String    @default("draft")
  onboardingStep   Int       @default(1)
  businessSettings Json?
  socialSettings   Json?
  gmailConnectedAt DateTime?
  gmailTokens      Json?
  dbMigrationNotes String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([orderId])
}

model Service {
  id               String          @id
  slug             String          @unique
  name             String
  shortDescription String
  fullDescription  String
  icon             String
  basePrice        Int
  isMonthly        Boolean         @default(false)
  timeline         String
  features         String[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  orderItems       OrderItem[]
  options          ServiceOption[]
  upsells          ServiceUpsell[]
}

model ServiceOption {
  id          String  @id @default(cuid())
  optionKey   String
  name        String
  description String
  price       Int
  isMonthly   Boolean @default(false)
  serviceId   String
  service     Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, optionKey])
}

model ServiceUpsell {
  id               String  @id @default(cuid())
  upsellKey        String
  name             String
  description      String
  kind             String?
  unit             String?
  pricePerUnit     Int?
  isMonthly        Boolean @default(false)
  min              Int?
  max              Int?
  defaultValue     Int?
  helperText       String?
  includedUnits    Int?
  tierStep         Int?
  tierPrice        Int?
  allowEntries     Boolean @default(false)
  entryLabel       String?
  entryPlaceholder String?
  choices          Json?
  serviceId        String
  service          Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, upsellKey])
}

model Order {
  id                           String               @id @default(cuid())
  userId                       String?
  customerName                 String
  customerEmail                String
  customerPhone                String
  customerCompany              String?
  customerNotes                String?
  totalOneTime                 Int
  totalMonthly                 Int
  status                       String               @default("pending")
  consultationId               String?              @unique
  pendingUserEmail             String?
  pendingUserPasswordHash      String?
  pendingUserName              String?
  pendingUserPhone             String?
  pendingUserCompany           String?
  postCheckoutToken            String?              @unique
  brandAssets                  Json?
  subscriptionRenewsAt         DateTime?
  stripeCheckoutMode           String?
  stripeCheckoutSessionId      String?              @unique
  stripePaymentIntentId        String?
  stripeSubscriptionId         String?
  stripeCustomerId             String?
  stripePaymentStatus          String?
  stripeCurrency               String?
  stripeAmountSubtotal         Int?
  stripeAmountTotal            Int?
  stripeAmountTax              Int?
  stripeMetadata               Json?
  stripeCheckoutCompletedAt    DateTime?
  stripePaidAt                 DateTime?
  createdAt                    DateTime             @default(now())
  updatedAt                    DateTime             @updatedAt
  /// * Set when customer + admin paid-order notification emails were sent (idempotent).
  paidConfirmationEmailsSentAt DateTime?
  consultation                 ConsultationBooking? @relation("OrderConsultation", fields: [consultationId], references: [id])
  user                         User?                @relation(fields: [userId], references: [id])
  items                        OrderItem[]
}

model OrderItem {
  id                 String  @id @default(cuid())
  serviceId          String
  serviceName        String
  selectedOptionId   String
  selectedOptionName String
  basePrice          Int
  totalPrice         Int
  totalOneTime       Int
  totalMonthly       Int
  isMonthly          Boolean @default(false)
  upsells            Json
  orderId            String
  order              Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  service            Service @relation(fields: [serviceId], references: [id])
}

model ConsultationBooking {
  id            String    @id
  name          String
  email         String
  phone         String
  company       String?
  notes         String?
  date          String
  time          String
  source        String
  status        String
  orderId       String?
  timezone      String    @default("Europe/Sofia")
  startsAt      DateTime?
  endsAt        DateTime?
  meetUrl       String?
  googleEventId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  linkedOrder   Order?    @relation("OrderConsultation")
}

model StripeCatalogMapping {
  id                  String   @id @default(cuid())
  lookupKey           String   @unique
  serviceId           String
  serviceName         String
  selectedOptionId    String
  selectedOptionName  String
  billingType         String
  unitAmount          Int
  currency            String   @default("eur")
  stripeProductId     String
  stripePriceId       String
  stripePaymentLinkId String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model StripeCustomerMapping {
  id               String   @id @default(cuid())
  customerEmail    String   @unique
  customerName     String?
  stripeCustomerId String   @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model StripeWebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  eventType     String
  orderId       String?
  processedAt   DateTime @default(now())
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  eventType String   @map("event_type")
  page      String
  metadata  Json?
  sessionId String?  @map("session_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([eventType, page])
  @@index([createdAt])
  @@index([sessionId])
  @@map("analytics_events")
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("coming-soon")
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("newsletter_subscribers")
}

model UtmLandingEvent {
  id          String   @id @default(cuid())
  page        String
  utmSource   String?  @map("utm_source")
  utmMedium   String?  @map("utm_medium")
  utmCampaign String?  @map("utm_campaign")
  utmPayload  Json     @map("utm_payload")
  dedupeKey   String   @unique @map("dedupe_key")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  landingUrl  String   @map("landing_url")

  @@index([createdAt])
  @@index([utmSource])
  @@index([utmMedium])
  @@index([utmCampaign])
  @@map("utm_landing_events")
}
